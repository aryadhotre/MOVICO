# App Configurations
APP_NAME="MOVICO Recommendation Service"
APP_ENV=development
DEBUG=true
PORT=8000
SECRET_KEY="replace-this-with-a-very-secure-random-key"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configurations
# Set USE_SQLITE=true to use local SQLite (no PostgreSQL needed)
# Set USE_SQLITE=false for production PostgreSQL
USE_SQLITE=true
POSTGRES_USER=movico_user
POSTGRES_PASSWORD=movico_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=movico_db

# Redis Caching Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CACHE_EXPIRE_SECONDS=3600

# TMDB API Configuration
# Get your free API key at: https://www.themoviedb.org/settings/api
# This enables rich movie metadata: posters, plots, cast, directors, etc.
TMDB_API_KEY=your-tmdb-api-key-here

# Model & Data Configuration
DATA_DIR="./data"
MODELS_DIR="./models_checkpoint"

# MovieLens Dataset URL
# Options:
#   https://files.grouplens.org/datasets/movielens/ml-latest-small.zip  (100K ratings - fast dev)
#   https://files.grouplens.org/datasets/movielens/ml-25m.zip           (25M ratings - large stable)
#   https://files.grouplens.org/datasets/movielens/ml-latest.zip        (33M+ ratings - biggest & latest)
MOVIELENS_DATASET_URL="https://files.grouplens.org/datasets/movielens/ml-latest.zip"

RECOMMENDATION_LIMIT=10
COLD_START_THRESHOLD=5

# Training Configuration
# For large datasets, sample this many ratings for SVD training (0 = use all)
TRAINING_SAMPLE_SIZE=5000000
SVD_EPOCHS=20
SVD_FACTORS=50
